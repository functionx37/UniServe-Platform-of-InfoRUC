# =========================
# OS / 文件系统生成文件
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# IDE / 编辑器配置
# 这些通常是个人本地配置，不建议提交
# =========================
.idea/
.vscode/
*.iml
*.ipr
*.iws

# =========================
# 日志与运行时临时文件
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 环境变量 / 本地敏感配置
# 不要把账号、密码、密钥提交到仓库
# =========================
.env
.env.*
!.env.example
!.env.sample
*.local

# =========================
# Node.js / 前端通用
# 适用于管理后台和未来的小程序构建工具
# =========================
node_modules/
dist/
build/
.cache/
.temp/
.tmp/
coverage/
*.tsbuildinfo

# =========================
# 微信小程序常见忽略项
# miniprogram_npm 为微信开发者工具构建产物
# 上传、预览、打包缓存通常也不需要入库
# =========================
miniprogram_npm/
.wxcloud/
.ttplatform/

# =========================
# Java / Maven / Spring Boot
# =========================
target/
out/
.mvn/timing.properties

# =========================
# 测试与压测产物
# =========================
test-output/
reports/
*.lcov
*.hprof

# =========================
# 压缩包 / 二进制产物
# 一般是导出结果或临时文件，不建议提交
# =========================
*.zip
*.tar
*.gz
*.rar
*.7z

# =========================
# 本地数据库 / 上传文件 / 临时资源
# 如果后续项目加入这些目录，可直接复用
# =========================
uploads/
tmp/
temp/
data/
