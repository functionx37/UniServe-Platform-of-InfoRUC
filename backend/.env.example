DB_URL=jdbc:kingbase8://localhost:54321/student_db
DB_USERNAME=system
DB_PASSWORD=system

APP_AES_KEY=replace-with-16-byte-key
APP_JWT_SECRET=replace-with-long-jwt-secret
APP_JWT_EXPIRATION=86400000

APP_STORAGE_ROOT=data
APP_KNOWLEDGE_DIR=knowledge-base
APP_CURRICULUM_DIR=curriculum
APP_TRANSCRIPT_DIR=transcripts
APP_PROOF_DIR=generated-proofs

LLM_BASE_URL=https://your-llm-endpoint.example.com/v1
LLM_API_TOKEN=your-api-token
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_MS=20000
