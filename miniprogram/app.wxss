page {
  --color-primary: #1d4ed8;
  --color-primary-weak: #dbeafe;
  --color-success: #16a34a;
  --color-warning: #d97706;
  --color-danger: #dc2626;
  --color-text: #111827;
  --color-text-muted: #6b7280;
  --color-bg: #f6f7fb;
  --color-surface: #ffffff;
  --color-border: #e5e7eb;
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 18rpx;
  --shadow-sm: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);

  background: var(--color-bg);
  color: var(--color-text);
  font-size: 32rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  border: 2rpx solid var(--color-border);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn {
  background: var(--color-primary);
  color: #ffffff;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  line-height: 1;
}

.btn-secondary {
  background: var(--color-surface);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  padding: 18rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  line-height: 1;
}

.input {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 18rpx 20rpx;
  border: 2rpx solid var(--color-border);
  color: var(--color-text);
}

.text-muted {
  color: var(--color-text-muted);
}

.u-page {
  min-height: 100vh;
  background: var(--color-bg);
}

.u-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.u-card--flat {
  box-shadow: none;
}

.u-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
}

.u-subtitle {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.u-text {
  font-size: 32rpx;
  color: var(--color-text);
}

.u-text--muted {
  color: var(--color-text-muted);
}

.u-divider {
  height: 2rpx;
  background: var(--color-border);
}

.u-btn {
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 32rpx;
  line-height: 1;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.u-btn--primary {
  background: var(--color-primary);
  color: #ffffff;
}

.u-btn--secondary {
  background: var(--color-surface);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.u-btn--danger {
  background: var(--color-danger);
  color: #ffffff;
}

button.u-btn::after {
  border: none;
}

.u-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: var(--color-primary-weak);
  color: var(--color-primary);
}

.u-tag--success {
  background: rgba(22, 163, 74, 0.12);
  color: var(--color-success);
}

.u-tag--warning {
  background: rgba(217, 119, 6, 0.12);
  color: var(--color-warning);
}

.u-tag--danger {
  background: rgba(220, 38, 38, 0.12);
  color: var(--color-danger);
}
