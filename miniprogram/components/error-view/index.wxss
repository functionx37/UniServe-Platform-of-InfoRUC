.u-error {
  padding: 40rpx 24rpx;
  text-align: center;
}

.u-error__icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: rgba(220, 38, 38, 0.08);
  color: var(--color-danger);
  margin: 0 auto 18rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.u-error__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.u-error__msg {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.u-error__btn {
  margin-top: 20rpx;
}
