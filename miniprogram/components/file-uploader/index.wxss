.u-upload {
  padding: 22rpx 24rpx;
}

.u-upload__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.u-upload__label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.u-upload__actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.u-upload__btn {
  padding: 16rpx 18rpx;
  font-size: 26rpx;
}

.u-upload__body {
  margin-top: 16rpx;
  padding: 18rpx 18rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: #ffffff;
}

.u-upload__placeholder {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.u-upload__name {
  color: var(--color-text);
  font-size: 28rpx;
}

.u-upload__tip {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
}
