.u-progress {
  width: 100%;
}

.u-progress__head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.u-progress__label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.u-progress__value {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.u-progress__track {
  width: 100%;
  height: 16rpx;
  background: #eef2ff;
  border-radius: 999rpx;
  overflow: hidden;
  border: 2rpx solid rgba(29, 78, 216, 0.08);
}

.u-progress__bar {
  height: 100%;
  border-radius: 999rpx;
  transition: width 200ms ease;
}
