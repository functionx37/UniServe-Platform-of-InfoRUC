.u-tl {
  width: 100%;
}

.u-tl__item {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.u-tl__left {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.u-tl__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d1d5db;
}

.u-tl__dot--done {
  background: var(--color-success);
}

.u-tl__dot--current {
  background: var(--color-primary);
  box-shadow: 0 0 0 0 rgba(29, 78, 216, 0.25);
  animation: u-breathe 1.6s ease-in-out infinite;
}

.u-tl__dot--todo {
  background: #9ca3af;
}

.u-tl__line {
  width: 4rpx;
  flex: 1;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
}

.u-tl__line--done {
  background: rgba(22, 163, 74, 0.35);
}

.u-tl__line--todo {
  background: #e5e7eb;
}

.u-tl__right {
  flex: 1;
  padding-bottom: 4rpx;
}

.u-tl__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.u-tl__title {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 600;
}

.u-tl__time {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.u-tl__desc {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

@keyframes u-breathe {
  0% {
    transform: scale(0.92);
    opacity: 0.7;
    box-shadow: 0 0 0 0 rgba(29, 78, 216, 0.22);
  }
  50% {
    transform: scale(1.12);
    opacity: 1;
    box-shadow: 0 0 0 12rpx rgba(29, 78, 216, 0.08);
  }
  100% {
    transform: scale(0.92);
    opacity: 0.7;
    box-shadow: 0 0 0 0 rgba(29, 78, 216, 0.22);
  }
}
