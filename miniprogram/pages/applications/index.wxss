.filters {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.filter {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  font-size: 26rpx;
  color: var(--color-text-muted);
  background: #ffffff;
}

.filter--active {
  color: var(--color-primary);
  border-color: rgba(29, 78, 216, 0.35);
  background: rgba(29, 78, 216, 0.06);
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  border-top: 2rpx solid var(--color-border);
}

.item:first-child {
  border-top: none;
}

.item__left {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.item__title {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 600;
}

.item__meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
}
