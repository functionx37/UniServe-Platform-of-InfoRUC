.filters {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.filter {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  font-size: 26rpx;
  color: var(--color-text-muted);
  background: #ffffff;
}

.filter--active {
  color: var(--color-primary);
  border-color: rgba(29, 78, 216, 0.35);
  background: rgba(29, 78, 216, 0.06);
}

.item {
  border-top: 2rpx solid var(--color-border);
}

.item:first-child {
  border-top: none;
}

.item__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 24rpx;
  gap: 16rpx;
}

.item__left {
  flex: 1;
  min-width: 0;
}

.item__title {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 600;
}

.item__meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.item__time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.item__read {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.item__unread {
  font-size: 24rpx;
  color: var(--color-primary);
}

.item__arrow {
  color: #9ca3af;
  font-size: 28rpx;
  padding-top: 6rpx;
}

.item__detail {
  padding: 0 24rpx 18rpx;
}

.item__content {
  font-size: 28rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  padding-top: 10rpx;
  border-top: 2rpx solid var(--color-border);
}

.item__links {
  margin-top: 12rpx;
}

.item__link {
  padding: 12rpx 0;
  border-top: 2rpx solid var(--color-border);
}

.item__link:first-child {
  border-top: none;
}

.item__linkTitle {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.item__linkUrl {
  font-size: 24rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.item__btn {
  padding: 14rpx 16rpx;
  font-size: 24rpx;
}
